---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SeriesNav from '../../components/SeriesNav.astro';
import BookMeta from '../../components/BookMeta.astro';
import NewsletterSignup from '../../components/NewsletterSignup.astro';
import { getCollection, render } from 'astro:content';
import { getSeries, getSeriesNavigation, getSeriesOverviewUrl } from '../../lib/series';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);

const data = entry.data;
const seriesData = data.type === 'seriesPart' ? data : null;
const bookData = data.type === 'bookReview' ? data : null;

const series = seriesData ? await getSeries(seriesData.series) : null;
const { prev: prevPost, next: nextPost } = series
  ? getSeriesNavigation(series, entry.id)
  : { prev: null, next: null };
---

<BaseLayout
  title={bookData ? `Book Review: ${bookData.book.title} — mynameisjonas` : `${data.title} — mynameisjonas`}
  description={bookData ? `${bookData.book.title} by ${bookData.book.author}. ${data.description}` : data.description}
  image={data.cover ?? bookData?.book.cover}
  type="article"
>
  <article class="animate-fade-in-up delay-0">
    <a href="/blog" class="text-sm text-accent hover:text-accent-hover transition-colors">&larr; Back to blog</a>

    <header class="mt-6 mb-8">
      {seriesData && (
        <p class="text-xs font-semibold uppercase tracking-wider text-accent mb-2">
          <a
            href={getSeriesOverviewUrl(seriesData.series)}
            class="hover:text-accent-hover transition-colors"
          >
            {series?.title ?? seriesData.series}
          </a>
        </p>
      )}
      <h1 class="text-3xl font-bold text-text-light dark:text-text-dark">
        {data.title}
      </h1>
      {bookData && (
        <p class="mt-1 text-base text-text-muted-light dark:text-text-muted-dark">by {bookData.book.author}</p>
      )}
      <time class="block mt-2 text-sm text-text-muted-light dark:text-text-muted-dark" datetime={data.date.toISOString()}>
        {data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
      </time>
      {data.tags.length > 0 && (
        <div class="flex flex-wrap gap-1.5 mt-3">
          {data.tags.map((tag) => (
            <span class="inline-block px-2 py-0.5 text-xs rounded-full bg-bg-light dark:bg-bg-dark border border-text-muted-light/20 dark:border-text-muted-dark/20 text-text-muted-light dark:text-text-muted-dark">
              {tag}
            </span>
          ))}
        </div>
      )}
    </header>

    {data.cover && !bookData && (
      <img
        src={data.cover}
        alt={data.title}
        class="w-full rounded-xl mb-8 border border-stone-200 dark:border-stone-800"
      />
    )}

    {seriesData && (
      <SeriesNav entry={entry} />
    )}

    {bookData && (
      <BookMeta {...bookData.book} />
    )}

    {bookData?.book.rating && (
      <div class="flex items-baseline gap-2 mb-8 -mt-2">
        <span class="text-accent text-xl tracking-wide">{'★'.repeat(bookData.book.rating)}{'☆'.repeat(5 - bookData.book.rating)}</span>
        <span class="text-sm text-text-muted-light dark:text-text-muted-dark">My rating</span>
      </div>
    )}

    <div class="prose max-w-none">
      <Content />
    </div>

    {seriesData?.series === 'gas-city' && (
      <NewsletterSignup
        heading="Enjoying the series?"
        description="I'll write more about multi-agent development and building with Gas City. No spam, unsubscribe any time."
      />
    )}

    <p class="mt-10 pt-6 border-t border-stone-200 dark:border-stone-800 text-sm text-text-muted-light dark:text-text-muted-dark">
      Have thoughts? <a href="https://x.com/jonaseriksson84" target="_blank" rel="noopener noreferrer" class="text-accent hover:text-accent-hover transition-colors">Find me on X</a> to continue the discussion.
    </p>

    {seriesData && (prevPost || nextPost) && (
      <nav class="mt-12 pt-6 border-t border-stone-200 dark:border-stone-800 flex justify-between gap-4">
        <div class="flex-1">
          {prevPost && (
            <a href={`/blog/${prevPost.id}`} class="group flex flex-col gap-0.5">
              <span class="text-xs text-text-muted-light dark:text-text-muted-dark">&larr; Previous</span>
              <span class="text-sm font-medium text-text-light dark:text-text-dark group-hover:text-accent transition-colors">
                {prevPost.data.title}
              </span>
            </a>
          )}
        </div>
        <div class="flex-1 text-right">
          {nextPost && (
            <a href={`/blog/${nextPost.id}`} class="group flex flex-col gap-0.5 items-end">
              <span class="text-xs text-text-muted-light dark:text-text-muted-dark">Next &rarr;</span>
              <span class="text-sm font-medium text-text-light dark:text-text-dark group-hover:text-accent transition-colors">
                {nextPost.data.title}
              </span>
            </a>
          )}
        </div>
      </nav>
    )}
  </article>
</BaseLayout>

<script>
  const COPY_ICON = `<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="14" height="14" x="8" y="8" rx="2" ry="2"/><path d="M4 16c-1.1 0-2-.9-2-2V4c0-1.1.9-2 2-2h10c1.1 0 2 .9 2 2"/></svg>`;
  const CHECK_ICON = `<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 15 4 10"/></svg>`;

  // Wrap intro (everything before first h2) in a styled block
  const prose = document.querySelector('.prose');
  const firstH2 = prose?.querySelector('h2');
  if (prose && firstH2) {
    const intro = document.createElement('div');
    intro.className = 'prose-intro';
    let el = prose.firstElementChild;
    while (el && el !== firstH2) {
      const next = el.nextElementSibling;
      intro.appendChild(el);
      el = next;
    }
    if (intro.children.length > 0) {
      prose.insertBefore(intro, firstH2);
    }
  }

  document.querySelectorAll('article pre').forEach((pre) => {
    const wrapper = document.createElement('div');
    wrapper.className = 'copy-code-wrapper';
    pre.parentNode!.insertBefore(wrapper, pre);
    wrapper.appendChild(pre);

    const button = document.createElement('button');
    button.innerHTML = COPY_ICON;
    button.setAttribute('aria-label', 'Copy code');
    button.setAttribute('title', 'Copy');
    button.className = 'copy-btn';
    wrapper.appendChild(button);

    button.addEventListener('click', () => {
      const code = pre.querySelector('code');
      navigator.clipboard.writeText(code?.innerText ?? '').then(() => {
        button.innerHTML = CHECK_ICON;
        setTimeout(() => { button.innerHTML = COPY_ICON; }, 1500);
      });
    });
  });
</script>

<style is:global>
  /* Wrapper restores the prose margins that pre would normally own */
  .copy-code-wrapper {
    position: relative;
    margin-top: 1.7143em;
    margin-bottom: 1.7143em;
  }

  .copy-code-wrapper pre {
    margin-top: 0 !important;
    margin-bottom: 0 !important;
  }

  .copy-btn {
    position: absolute;
    top: 0.5rem;
    right: 0.5rem;
    width: 1.75rem;
    height: 1.75rem;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 0.3rem;
    border: 1px solid #44403c;
    background: #1c1917cc;
    color: #78716c;
    cursor: pointer;
    transition: color 0.15s ease, background 0.15s ease;
  }

  .copy-btn:hover {
    color: #fafaf9;
    background: #292524;
  }
</style>
