---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('blog');
const seriesPosts = allPosts
  .filter((p) => p.data.series === 'building-with-gas-city' && !p.data.draft)
  .sort((a, b) => (a.data.part ?? 0) - (b.data.part ?? 0));

const first = seriesPosts[0];
---

<BaseLayout
  title="Building with Gas City — Jonas Eriksson"
  description={first?.data.seriesDescription}
  image="/blog/gas-city/cover-00.png"
  type="article"
>
  <article class="animate-fade-in-up delay-0">
    <a href="/blog" class="text-sm text-accent hover:text-accent-hover transition-colors">&larr; Back to blog</a>

    <img
      src="/blog/gas-city/cover-00.png"
      alt="Building with Gas City"
      class="w-full rounded-xl mt-6 mb-6 border border-stone-200 dark:border-stone-800"
    />

    <header class="mb-8">
      <p class="text-xs font-semibold uppercase tracking-wider text-accent mb-2">
        Series &middot; {seriesPosts.length} parts
      </p>
      <h1 class="text-3xl font-bold text-text-light dark:text-text-dark">
        Building with Gas City
      </h1>
      <div class="flex flex-wrap items-center gap-x-2 gap-y-1 mt-2">
        <time
          class="text-xs text-text-muted-light dark:text-text-muted-dark"
          datetime={first?.data.date.toISOString()}
        >
          {first?.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
        </time>
        {first?.data.tags.map((tag) => (
          <span class="inline-block px-2 py-0.5 text-xs rounded-full bg-bg-light dark:bg-bg-dark border border-text-muted-light/20 dark:border-text-muted-dark/20 text-text-muted-light dark:text-text-muted-dark">
            {tag}
          </span>
        ))}
      </div>
      {first?.data.seriesDescription && (
        <p class="text-base text-text-muted-light dark:text-text-muted-dark mt-4 leading-relaxed">
          {first.data.seriesDescription}
        </p>
      )}
    </header>

    <ol class="space-y-3 border-l-2 border-accent/30 pl-5">
      {seriesPosts.map((post) => (
        <li>
          <a href={`/blog/${post.id}`} class="group flex items-start gap-3 py-1">
            <span class="text-xs font-mono text-text-muted-light dark:text-text-muted-dark w-6 shrink-0 tabular-nums mt-1">
              {String(post.data.part ?? 0).padStart(2, '0')}
            </span>
            <div>
              <span class="text-base font-medium text-text-light dark:text-text-dark group-hover:text-accent transition-colors">
                {post.data.title.replace(/^Part \d+:\s*/i, '')}
              </span>
              <p class="text-sm text-text-muted-light dark:text-text-muted-dark mt-0.5">
                {post.data.description}
              </p>
            </div>
          </a>
        </li>
      ))}
    </ol>
  </article>
</BaseLayout>
