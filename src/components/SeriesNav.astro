---
import type { CollectionEntry } from 'astro:content';
import { getSeries } from '../lib/series';

interface Props {
  entry: CollectionEntry<'blog'>;
}

const { entry } = Astro.props;
const data = entry.data;
const series = data.type === 'seriesPart' ? await getSeries(data.series) : null;
---
{series && (
  <nav class="mb-10 rounded-lg border border-stone-200 dark:border-stone-800 bg-stone-50 dark:bg-stone-900/50 p-4">
    <a
      href={series.overviewUrl}
      class="text-xs font-semibold uppercase tracking-wider text-text-muted-light dark:text-text-muted-dark hover:text-accent transition-colors mb-3 block"
    >
      {series.title}
    </a>
    <div class="mb-3 pb-3 border-b border-stone-200 dark:border-stone-800">
      <a href={series.overviewUrl} class="text-xs text-text-muted-light dark:text-text-muted-dark hover:text-accent transition-colors">
        Series overview &rarr;
      </a>
    </div>
    <ol class="space-y-1.5">
      {series.parts.map((post) => {
        const isCurrent = post.id === entry.id;
        return (
          <li class="flex items-baseline gap-2">
            <span class="text-xs text-text-muted-light dark:text-text-muted-dark w-4 shrink-0 text-right">
              {post.data.part}
            </span>
            {isCurrent ? (
              <span class="text-sm font-semibold text-accent">
                {post.data.title}
              </span>
            ) : (
              <a
                href={`/blog/${post.id}`}
                class="text-sm text-text-muted-light dark:text-text-muted-dark hover:text-accent transition-colors"
              >
                {post.data.title}
              </a>
            )}
          </li>
        );
      })}
    </ol>
  </nav>
)}
